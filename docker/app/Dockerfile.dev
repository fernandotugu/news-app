FROM php:8.3-fpm

ARG UID=1000
ARG GID=1000

RUN apt-get update && apt-get install -y \
    git unzip curl zip \
    libzip-dev libpng-dev libonig-dev libxml2-dev \
    && docker-php-ext-install pdo_mysql mbstring zip exif pcntl bcmath gd

# Coverage driver for Pest/PHPUnit (--coverage)
RUN pecl install pcov \
    && docker-php-ext-enable pcov \
    && echo "pcov.enabled=1" > /usr/local/etc/php/conf.d/pcov.ini

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www

# Copia tudo primeiro (simples e correto para dev)
COPY application /var/www

# Instala dependências
RUN composer install --no-interaction --prefer-dist

RUN apt-get update && apt-get install -y nodejs npm

# node_modules no build (em runtime o volume nomeado pode vazio; o entrypoint corre com npm ci)
RUN npm ci --no-audit --no-fund

# Permissões (mkdir antes do chmod: a pasta storage pode não vir no COPY)
RUN mkdir -p \
    storage/app/public \
    storage/framework/cache/data \
    storage/framework/sessions \
    storage/framework/testing \
    storage/framework/views \
    storage/logs \
    bootstrap/cache \
    && chmod -R 777 storage bootstrap/cache

# Usuário não-root para evitar arquivos root no bind mount
RUN groupadd -g ${GID} appuser \
    && useradd -u ${UID} -g appuser -m appuser \
    && chown -R appuser:appuser /var/www

EXPOSE 9000

COPY docker/app/entrypoint.sh /usr/local/bin/entrypoint.sh

RUN chmod +x /usr/local/bin/entrypoint.sh

USER appuser

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

CMD ["php-fpm"]